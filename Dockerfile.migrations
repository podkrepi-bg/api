FROM node:19-alpine3.17 as base
WORKDIR /app

COPY .yarnrc.yml package.json yarn.lock ./
COPY .yarn .yarn
RUN yarn install --immutable

COPY schema.prisma .
COPY migrations migrations/

USER 1000:1001

CMD yarn prisma migrate deploy

FROM base AS seed
USER 0
COPY . .
CMD yarn prisma generate && yarn prisma db seed
