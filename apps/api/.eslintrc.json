{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@typescript-eslint/no-empty-function": ["off"]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@nestjs/common",
                "importNames": ["UploadedFile", "UploadedFiles"],
                "message": "Import UploadedFile/UploadedFiles from 'src/common/uploaded-file.decorator' instead. The custom decorators re-encode `file.originalname` from latin1 to UTF-8 so non-ASCII filenames are stored correctly."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    }
  ]
}
